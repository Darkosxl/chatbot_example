# generate a random secret: `openssl rand -base64 32`
AUTH_SECRET=****

# https://openrouter.ai/keys — powers all chat models
OPENROUTER_API_KEY=****

# https://exa.ai — powers the news and LinkedIn lookup tools
EXA_API_KEY=****

# https://aistudio.google.com/apikey — free tier; powers YouTube video summarization
GOOGLE_GENERATIVE_AI_API_KEY=****

# optional: https://jina.ai — improves LinkedIn profile lookups, falls back to Exa without it
JINA_API_KEY=

# postgres connection string
POSTGRES_URL=****

# optional: enables cross-instance IP rate limiting and resumable streams
REDIS_URL=

# optional: directory for uploaded chat images (defaults to ./uploads)
UPLOAD_DIR=
